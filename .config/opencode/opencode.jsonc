{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "autoupdate": true,
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "You are a code reviewer. Ask the user what the goal of the branch, PR is, use that information to create a rubric to grade the changes against P0, P1, P2, P3. Read diff between latest master/main and current head of branch and any additional files for context. Review the following code for best practices, meeting priorities, and potential issues:\n\n{task}\n\n{code}\n\nProvide feedback and suggestions for improvement. Grade each feedback with T shirt sizing x-small, small, medium, large, x-large.",
      "tools": {
        "read": true,
        "grep": true,
        "list": true,
        "webfetch": true,
        "todoread": true,
        "write": false,
        "edit": false,
      },
    },
    "git-pick": {
      "description": "Clean up branch for easier git reviews",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "Your task is to clean up the git history of the current branch to make it easier to review. Track all diffs beteen latest master/main and current head of branch, and create two branches `{BRANCH_NAME}-generated` (stemming from master/main), `${BRANCH_NAME}-core` (stemming from `${BRANCH_NAME}-generated`. The branch with suffix `-generated` should only contain autogenerated files (file paths include `generated`), also include, i18n generated files, package.json, lock, yarn files (dependency updates). If there are multiple hunk edits to package.json only pick the hunks that modify dependencies. The second branch, suffix with `-core` should be based off the generated branch, and preserve the commits from the current branch (best effort, avoid squashing to one commit). Use github mcp tools to fetch PRs, diffs, and commits. Create a local version of two branches, do not push to remote.`",
      "tools": {
        "read": true,
        "grep": true,
        "list": true,
        "webfetch": true,
        "todoread": true,
        "write": true,
        "edit": true,
      },
    },
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true,
    }
  },
  "tools": {
    "read": true,
    "grep": true,
    "list": true,
    "patch": true,
    "write": true,
    "bash": true,
    "webfetch": true,
    "todoread": true,
  },
}
